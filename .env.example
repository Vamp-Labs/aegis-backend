# Server
PORT=3000
NODE_ENV=development

# Blockchain
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
CHAIN_ID=11155111

# Contract Addresses (deployed on target network)
AEGIS_SENTINEL_ADDRESS=0x...
RISK_ORACLE_ADDRESS=0x...
SAFE_HAVEN_REGISTRY_ADDRESS=0x...

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=1h

# Auth
NONCE_TTL_SECONDS=300
SIGNATURE_MESSAGE_PREFIX=Aegis Sentinel Authentication

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=10
